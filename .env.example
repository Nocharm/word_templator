# 이 파일은 docker-compose 의 변수 substitution + backend 컨테이너 env_file 로 사용된다.
# Backend 는 pydantic-settings 로 ../.env / .env 다중 경로 시도 → 로컬 dev 시 backend/ 에서
# 실행해도 루트 .env 를 찾는다. Frontend 는 env_file 미사용 — docker-compose 가 NEXT_PUBLIC_*
# 만 빌드 ARG + 런타임 environment 로 전달한다 (백엔드 시크릿이 프론트 컨테이너로 새지 않음).

# === Backend (서버 전용 시크릿) ===
DATABASE_URL=sqlite:////data/app.db
JWT_SECRET=change_me_64_chars             # `openssl rand -hex 32`
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=72
DATA_DIR=/data
FILE_RETENTION_DAYS=30
CORS_ORIGINS=http://localhost:3000
AUTH_PROVIDER=local
# 콤마 구분 — 해당 이메일로 signup 시 자동 admin 권한 부여
ADMIN_EMAILS=

# === Frontend (NEXT_PUBLIC_* 만 클라이언트 번들에 인라인) ===
# 기본값 /api → nginx 프록시 환경에서 작동. 다른 호스트 배포 시 절대 URL 로 변경
# (예: https://example.com/api). docker-compose 가 build ARG 로 전달해 JS 번들에 인라인.
NEXT_PUBLIC_API_BASE=/api
